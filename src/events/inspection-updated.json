{
  "name": "inspection-updated",
  "description": "Inspection updated event",
  "attributes": [
    {
      "name": "inspectionId",
      "type": "string",
      "description": "Inspection ID (uuid)",
      "required": true
    },
    {
      "name": "propertyId",
      "type": "string",
      "description": "Property ID (uuid)",
      "required": true
    },
    {
      "name": "agencyId",
      "type": "string",
      "description": "Agency ID (uuid)",
      "required": true
    },
    {
      "name": "inspectorId",
      "type": "string",
      "description": "Inspector ID (uuid)",
      "required": true
    },
    {
      "name": "elements",
      "description": "Elements inspected",
      "arrayOf": {
        "description": "Element",
        "attributes": [
          {
            "name": "elementId",
            "type": "string",
            "description": "Element ID (uuid)",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "description": "Element name",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "description": "Element description"
          },
          {
            "name": "state",
            "enum": ["NEW", "GOOD", "BAD", "BROKEN", "MISSING"],
            "description": "Element state",
            "required": true
          }
        ]
      }
    },
    {
      "name": "date",
      "type": "string",
      "description": "Inspection date, in IsoString format: YYYY-MM-DDTHH:mm:ss.sssZ",
      "required": true
    },
    {
      "name": "status",
      "enum": ["TO_DO", "IN_PROGRESS", "DONE", "CANCELED"],
      "description": "Inspection status",
      "required": true
    }
  ]
}
